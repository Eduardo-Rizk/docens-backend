# ─── Local Postgres (default for dev) ────────────────────────────────
# Run `make db-local-setup` to start Postgres via Docker and apply migrations
DATABASE_URL="postgresql://docens:docens@localhost:5432/docens"
DIRECT_URL="postgresql://docens:docens@localhost:5432/docens"

# ─── Remote Supabase (optional, for staging/prod) ───────────────────
# DATABASE_URL="postgres://[USER].[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://[USER].[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# ─── Auth (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY="[from Clerk Dashboard]"
CLERK_JWKS_URI="[from Clerk Dashboard]"

PORT=3001
NODE_ENV=development
