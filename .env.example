DATABASE_URL="postgres://[USER].[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://[USER].[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[from Supabase Dashboard > Settings > API > anon public]"
SUPABASE_SERVICE_ROLE_KEY="[from Supabase Dashboard > Settings > API > service_role]"
SUPABASE_JWT_SECRET="[from Supabase Dashboard > Settings > API > JWT Settings - NOT the anon key]"
PORT=3001
NODE_ENV=development
